.container
  %h1 Articles
  = link_to 'New article', new_admin_article_path, role: 'button', class: 'btn btn-primary btn-lg'
  - if @articles.size > 0
    %table.table
      %thead
        %tr
          %th{scope: 'col'}id
          %th{scope: 'col'}title
          %th{scope: 'col'}content
          %th{scope: 'col'}user_id
          %th{scope: 'col'}actions
      %tbody
        - @articles.each do |article|
          %tr
            %th{scope: 'row'}= article.id
            %td
              = link_to article.title, admin_article_path(article)
            %td= article.content.truncate(60)
            %td= article.user.id
            %td
              .d-flex.justify-content-evenly
                = link_to 'Edit', edit_admin_article_path(article), role: 'button', class: 'btn btn-info'
                = link_to 'Delete', admin_article_path(article), data: {turbo_method: :delete, turbo_confirm: 'Are you sure?'}, role: 'button', class: 'btn btn-danger'
